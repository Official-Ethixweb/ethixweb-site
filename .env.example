# ── Resend (email delivery for contact form) ──────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Site URL (used for sitemap, canonical URLs, email templates) ──────────────
# Set to your production domain without trailing slash
VITE_SITE_URL=https://ethixweb.com

# ── Vercel Blob (resume uploads for the Careers application form) ─────────────
# Created automatically when you add a Blob store to your Vercel project,
# or via: npx vercel env pull (after `vercel blob store add`)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (durable lead records + AI candidate screening) ──────────────────
# Run every file in supabase/migrations/ once, in order, in a new Supabase
# project's SQL editor (see supabase/README.md), then get these from Project
# Settings -> API. Use the *service role* key, not the anon key - every table
# has RLS enabled with no anon policy on purpose. Without these set, the
# contact/careers-apply forms still work via email only (no durable record),
# and the AI screening endpoints are unavailable.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional - defaults to claude-sonnet-5 if unset
ANTHROPIC_SCREENING_MODEL=claude-sonnet-5

# Random long string - signs the approve/reject links in the reviewer email
# so they can't be forged. Generate with: openssl rand -hex 32
SCREENING_ACTION_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where scored results + approve/reject links get emailed (Amar/Disha)
SCREENING_REVIEWER_EMAIL=you@ethixweb.com
